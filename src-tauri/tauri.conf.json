{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BJIFF 排片助手",
  "version": "1.0.0",
  "identifier": "com.sunnyfiee.bjiffhelper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "BJIFF 排片助手",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "acceptFirstMouse": true,
        "decorations": true,
        "shadow": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
